# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
RAW_BUCKET=automotive-raw-data-lerato-2026
STAGING_BUCKET=automotive-staging-data-lerato-2026
ARCHIVE_BUCKET=automotive-archive-data-lerato-2026

# Warehouse
DB_HOST_EXTERNAL=your-managed-postgres-host
DB_PORT=5432
DB_NAME=automative_warehousee_ygg3
DB_USER=warehouse_user
DB_PASSWORD=your-managed-postgres-password
DATABASE_URL_EXTERNAL=postgresql://warehouse_user:password@your-managed-postgres-host:5432/automative_warehousee_ygg3

# Airflow and Monitoring
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
PIPELINE_SLA_THRESHOLD_SECONDS=600

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_MAIL_FROM=airflow-notifications@automativedata.com
SMTP_TO=your-alert-recipient@example.com
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/your-webhook