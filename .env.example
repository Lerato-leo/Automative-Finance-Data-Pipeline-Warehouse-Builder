# ============================================
# AWS Configuration
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# S3 Bucket Names
RAW_BUCKET=automotive-raw-data-lerato-2026
STAGING_BUCKET=automotive-staging-data-lerato-2026
ARCHIVE_BUCKET=automotive-archive-data-lerato-2026

# SQS Queue URL (obtained from Phase 5 setup)
RAW_S3_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/automotive-raw-s3-events

# ============================================
# Database Configuration
# ============================================
# Render PostgreSQL (External)
DB_HOST_EXTERNAL=dpg-xxxxx.oregon-postgres.render.com
DB_PORT=5432
DB_NAME=automative_warehousee_ygg3
DB_USER=warehouse_user
DB_PASSWORD=your-secure-password
DATABASE_URL_EXTERNAL=postgresql://warehouse_user:password@dpg-xxxxx.oregon-postgres.render.com:5432/automative_warehousee_ygg3

# Docker Internal PostgreSQL (for Airflow metadata)
DB_HOST=postgres
AIRFLOW_POSTGRES_HOST_PORT=5433

# ============================================
# SMTP Configuration (Email Notifications)
# ============================================
# Gmail SMTP (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx  # Use Gmail App Password, not regular password
SMTP_MAIL_FROM=airflow-notifications@automativedata.com

# Alternative: Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASSWORD=your-office-365-password

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key

# ============================================
# Microsoft Teams Webhook (for DAG alerts)
# ============================================
# Create webhook here: Teams > Channel > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/xxxxxxxxxxxxx/IncomingWebhook/xxxxxxxxxxxxxxxx

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW_HOME=/opt/airflow
AIRFLOW_EXECUTOR=CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False
AIRFLOW__CORE__PLUGINS_FOLDER=/opt/airflow/plugins

# ============================================
# Kafka Configuration (Phase 6)
# ============================================
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=automotive-raw-data
KAFKA_CONSUMER_GROUP=airflow-consumer
KAFKA_AUTO_OFFSET_RESET=earliest

# ============================================
# Logging/Monitoring
# ============================================
LOG_LEVEL=INFO
ENABLE_XCOM_PICKLING=True
